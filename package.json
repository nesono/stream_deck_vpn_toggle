{
  "name": "stream_deck_vpn_toggle",
  "version": "1.0.0",
  "description": "Stream Deck plugin to toggle macOS VPN connections",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "link": "streamdeck link com.jochenissing.vpn-toggle.sdPlugin",
    "pack": "streamdeck pack com.jochenissing.vpn-toggle.sdPlugin"
  },
  "keywords": [
    "stream-deck",
    "vpn"
  ],
  "author": "Jochen Issing",
  "license": "MIT",
  "dependencies": {
    "@elgato/streamdeck": "^2.0.2"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
